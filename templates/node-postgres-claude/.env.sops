# Skeleton SOPS-encrypted env file.
#
# This is intentionally a placeholder. Run:
#   sops .env.sops
# to populate real values once your age public key is in .sops.yaml.
#
# When properly encrypted, every line below the first will be ciphertext.
DATABASE_URL=ENC[AES256_GCM,data:placeholder,iv:placeholder,tag:placeholder,type:str]
ANTHROPIC_API_KEY=ENC[AES256_GCM,data:placeholder,iv:placeholder,tag:placeholder,type:str]
PORT=ENC[AES256_GCM,data:placeholder,iv:placeholder,tag:placeholder,type:str]
sops:
  kms: []
  gcp_kms: []
  azure_kv: []
  hc_vault: []
  age:
    - recipient: age1placeholderxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
      enc: |
        -----BEGIN AGE ENCRYPTED FILE-----
        PLACEHOLDER-REPLACE-ME-BY-RUNNING-SOPS-EDIT
        -----END AGE ENCRYPTED FILE-----
  lastmodified: "1970-01-01T00:00:00Z"
  mac: ENC[AES256_GCM,data:placeholder,iv:placeholder,tag:placeholder,type:str]
  unencrypted_suffix: _unencrypted
  version: 3.9.1
