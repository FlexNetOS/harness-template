# .env.example — copy to .env (dev only, gitignored) OR populate .env.sops.
# Production: ALWAYS use .env.sops; never commit a real .env.

# Postgres connection string. Default points at the docker-compose service.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/app

# Anthropic API key for the Claude CLI inside the devcontainer.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# HTTP port the Express app listens on.
PORT=3000

# Node environment.
NODE_ENV=development
