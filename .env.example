# =============================================================================
# .env schema (plaintext) — copy this to populate .env.sops, then encrypt.
# .env itself is .gitignore'd and never written to disk inside the devcontainer.
# =============================================================================

# --- Claude CLI -------------------------------------------------------------
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Codex CLI --------------------------------------------------------------
# Either OPENAI_API_KEY (non-interactive) OR run `codex login` interactively.
OPENAI_API_KEY=sk-...

# --- Gemini CLI -------------------------------------------------------------
# Either GOOGLE_API_KEY (non-interactive) OR run `gemini auth` interactively.
GOOGLE_API_KEY=AIza...

# --- Repo metadata ----------------------------------------------------------
GITHUB_REPO=FlexNetOS/harness-template

# --- Optional: telemetry/observability --------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=harness-template
